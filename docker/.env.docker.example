# =============================================================================
# Docker Environment — Giải Bóng đá Đoàn phường
# Sao chép: cp docker/.env.docker.example docker/.env
# =============================================================================

# --- Application ---
APP_NAME="Giải Bóng đá Đoàn phường"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate

# --- Ports (host mapping) ---
HTTP_PORT=8080
HTTPS_PORT=443
FRONTEND_DEV_PORT=3000
BACKEND_DEV_PORT=9000
POSTGRES_PORT=5432
REDIS_PORT=6379
REVERB_PORT=8081

# --- PostgreSQL ---
POSTGRES_DB=giai_bong_da
POSTGRES_USER=giai_bong_da
POSTGRES_PASSWORD=change_me_strong_password_here

# --- Redis ---
REDIS_PASSWORD=

# --- JWT (Laravel Sanctum / tymon/jwt-auth) ---
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_TTL=60
JWT_REFRESH_TTL=20160

# --- Laravel Reverb (WebSocket) ---
REVERB_APP_ID=giai-bong-da
REVERB_APP_KEY=change_me_reverb_key
REVERB_APP_SECRET=change_me_reverb_secret

# --- Frontend (Next.js public env) ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_APP_NAME="Giải Bóng đá Đoàn phường"

# --- Storage ---
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=

# --- Mail (optional) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@doanphuong.local
MAIL_FROM_NAME="${APP_NAME}"

# --- Logging ---
LOG_LEVEL=debug

# --- Backup ---
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"
