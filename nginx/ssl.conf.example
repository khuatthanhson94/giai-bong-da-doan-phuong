# SSL/TLS configuration example
# 1. Đặt certificate vào volume ssl_certs hoặc mount trực tiếp
# 2. Copy file này thành ssl.conf và bật redirect HTTP -> HTTPS

# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name giaibongda.doanphuong.vn www.giaibongda.doanphuong.vn;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name giaibongda.doanphuong.vn www.giaibongda.doanphuong.vn;

    ssl_certificate     /etc/nginx/ssl/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/privkey.pem;

    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;

    client_max_body_size 64M;

    # Include same location blocks as default.conf
    # Trong production, merge hoặc include file chung:
    include /etc/nginx/conf.d/default-locations.conf;

    # Hoặc dùng certbot:
    # certbot certonly --webroot -w /var/www/certbot -d giaibongda.doanphuong.vn
}
