{
  "outputDirectory": "client/dist",
  "env": {
    "VITE_API_URL": "https://giai-bong-da-api-v3.onrender.com"
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
